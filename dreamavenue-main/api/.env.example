# --- App ---
PORT=4000
APP_PATH=http://localhost:4000
FRONTEND_URL=http://localhost:3008
DEV_MODE=true
LOAD_DATA=true

# --- Database (matches docker-compose postgres service) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=dreamavenue
DB_PASSWORD=
DB_NAME=dreamavenue

# --- Redis (matches docker-compose redis service) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_SECRET=

# --- OAuth (a value is required or passport strategies crash on boot; Google/Facebook login won't work without real values) ---
GOOGLE_CLIENT_ID=placeholder-google-client-id
GOOGLE_CLIENT_SECRET=placeholder-google-client-secret
FACEBOOK_CLIENT_ID=placeholder-facebook-client-id
FACEBOOK_CLIENT_SECRET=placeholder-facebook-client-secret

# --- Mail (local dev: point at MailHog, view sent emails at http://localhost:8025) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=mailhog
SMTP_PASSWORD=mailhog
SMTP_DEFAULT_FROM=noreply@dreamavenue.local

# --- Log viewer (Basic Auth for /log-viewer) ---
LOG_VIEWER_USER=admin
LOG_VIEWER_PASS=

# --- File storage (local disk) ---
UPLOAD_PATH=./uploads
FILE_STORAGE_PATH=./storage

# --- Third-party analysis APIs (leave blank: property market-data lookups will just return no data without real keys) ---
HERE_API_KEY=
RENTCAST_API_KEY=
DATAFINITI_API_KEY=
