<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{@root.property.title}} - Property Dashboard</title>
  <!-- Bootstrap CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" xintegrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <!-- Google Fonts for Plus Jakarta Sans -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

  <!-- Chart.js CDN for chart rendering -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    /* Apply Plus Jakarta Sans to the body */
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: #f8fafc; /* A very light grey background */
      color: #334155; /* A dark grey for general text */
    }
    .form-switch .form-check-input {
      width: 3.5em;
      height: 2em;
      cursor: pointer;
    }
    /* Custom scrollbar for improved aesthetics, particularly for overflow-auto sections */
    ::-webkit-scrollbar {
      width: 8px; /* Width of vertical scrollbar */
      height: 8px; /* Height of horizontal scrollbar */
    }
    ::-webkit-scrollbar-track {
      background: #f1f5f9; /* Color of the scrollbar track */
      border-radius: 10px; /* Rounded corners for the track */
    }
    ::-webkit-scrollbar-thumb {
      background: #cbd5e1; /* Color of the scrollbar thumb */
      border-radius: 10px; /* Rounded corners for the thumb */
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8; /* Color of the scrollbar thumb on hover */
    }
    /* Custom styling for the range input (slider) for better appearance */
    input[type='range'] {
      -webkit-appearance: none; /* Override default look */
      width: 100%; /* Full width */
      height: 8px; /* Height of the track */
      background: #e2e8f0; /* Light grey track */
      border-radius: 5px;
      outline: none;
      cursor: pointer;
    }

    input[type='range']::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 20px; /* Size of the thumb */
      height: 20px;
      background: #4A90E2; /* Blue thumb */
      border-radius: 50%; /* Circular thumb */
      border: 2px solid #fff; /* White border */
      box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.4); /* Blue shadow */
      margin-top: -6px; /* Center thumb vertically on track */
    }

    input[type='range']::-moz-range-thumb {
      width: 20px;
      height: 20px;
      background: #4A90E2;
      border-radius: 50%;
      border: 2px solid #fff;
      box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.4);
    }

  </style>
</head>
<body class="p-4 p-md-8">
<!-- Main container for the dashboard, centered and with a max-width -->
<div class="container-fluid py-4">
  <div class="row g-4">
    {{{content}}}
  </div>
</div>

<!-- Bootstrap Bundle with Popper (for JavaScript components) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" xintegrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
