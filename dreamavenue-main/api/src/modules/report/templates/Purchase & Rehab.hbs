
<!-- Section 4: Purchase & Costs Card -->
<div class="col-lg-8">
  <div class="card shadow-sm rounded-lg h-100">
    <div class="card-body p-4">
      <h5 class="card-title mb-3">Purchase & Costs</h5>
      <ul class="list-unstyled mb-0 small">
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Purchase Price</span>
          <span class="font-weight-semibold text-gray-700">${{formatNumber purchase_price}}</span>
        </li>
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Rehab Costs</span>
          <span class="font-weight-semibold text-gray-700">${{formatNumber rehab_costs}}</span>
        </li>
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Closing Costs</span>
          <span class="font-weight-semibold text-gray-700">${{formatNumber closing_costs}}</span>
        </li>
        <li class="border-top my-2"></li>
        <li class="d-flex justify-content-between align-items-center font-weight-bold h6">
          <span class="text-gray-700">Purchase Costs</span>
          <span class="text-success">${{formatNumber purchase_costs}}</span>
        </li>
      </ul>
    </div>
  </div>
</div>
<!-- Section 5: Purchase & Rehab Card (from Picture1) -->
<div class="col-lg-8">
  <div class="card shadow-sm rounded-lg h-100">
    <div class="card-body p-4">
      <h5 class="card-title mb-3">Purchase & Rehab</h5>
      <ul class="list-unstyled mb-0 small">
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Purchase Price</span>
          <span class="font-weight-semibold text-gray-700">$350,000</span>
        </li>
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Rehab Budget</span>
          <span class="font-weight-semibold text-gray-700">$50,000</span>
        </li>
        <li class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-gray-600">Closing Costs</span>
          <span class="font-weight-semibold text-gray-700">$10,000</span>
        </li>
        <li class="border-top my-2"></li>
        <li class="d-flex justify-content-between align-items-center font-weight-bold h6">
          <span class="text-gray-700">Total Project Cost</span>
          <span class="text-success">$410,000</span>
        </li>
      </ul>
    </div>
  </div>
</div>


<!-- Section 5: Tax Assessment History Card -->
<div class="col-lg-8">
  <div class="card shadow-sm rounded-lg h-100">
    <div class="card-body p-4">
      <h5 class="card-title mb-3">Tax Assessment History</h5>
      <ul class="list-unstyled mb-0 small">
        {{#each sourceData.taxAssessments}}
          <li class="mb-3 pb-2 {{#unless @last}}border-bottom{{/unless}}">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <span class="text-gray-600 font-weight-medium">{{year}}</span>
              <span class="font-weight-bold text-gray-700">${{formatNumber value}}</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-gray-500" style="font-size: 0.75rem;">Land: ${{formatNumber land}}</span>
              <span class="text-gray-500" style="font-size: 0.75rem;">Improvements: ${{formatNumber improvements}}</span>
            </div>
          </li>
        {{/each}}
      </ul>
    </div>
  </div>
</div>
