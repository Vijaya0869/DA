<div style="font-family: Arial, sans-serif; color: #000; margin: 0; padding: 0; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">

        <!-- Greeting -->
        <h2 style="font-size: 28px; margin: 0 0 20px 0; padding: 10px 0;">Hi {{username}},</h2>

        <!-- Title -->
        <h1 style="font-size: 32px; margin: 0 0 20px 0; padding: 10px 0;">Welcome to Dream Avenue!</h1>

        <!-- Body Text -->
        <p style="font-size: 18px; margin: 0 0 30px 0;">
            We're excited to have you on board! To get started, please verify your email address by clicking the button
            below.
        </p>

        <!-- Verify Email Button -->
        <div style="text-align: center; margin-top: 20px;">
            <a href="{{inviteLink}}"
                style="display: inline-block; background-color: #007bff; color: white; padding: 12px 25px; text-align: center; text-decoration: none; border-radius: 5px; font-size: 18px;">
                Verify Your Email
            </a>
        </div>

        <!-- Additional Text -->
        <p style="font-size: 16px; margin-top: 20px;">
            If you did not sign up for Dream Avenue, please ignore this email. Your account has not been created.
        </p>

        <!-- Footer (Optional) -->
        <p style="font-size: 14px; color: #777; margin-top: 20px;">
            If you have any questions or need assistance, feel free to contact us at <a
                href="mailto:dreamavenue.noreply@gmail.com" style="color: #007bff;">dreamavenue.noreply@gmail.com</a>.
        </p>
    </div>
</div>